<!-- Chatbot NEX -->
<button class="nex-toggle" id="nexToggle" aria-label="Ouvrir le chat NEX">
  <i class="bi bi-robot"></i>
  <span class="nex-pulse"></span>
</button>
<div class="nex-bubble" id="nexBubble" role="dialog" aria-label="Chat NEX">
  <div class="nex-head">
    <div class="nex-head-info">
      <div class="nex-avatar">🤖</div>
      <div>
        <div class="nex-name">NEX — Assistant IA</div>
        <div class="nex-status"><span class="nex-online"></span>En ligne · Propulsé par Groq</div>
      </div>
    </div>
    <button class="nex-close" id="nexClose" aria-label="Fermer"><i class="bi bi-x-lg"></i></button>
  </div>
  <div class="nex-messages" id="nexMessages">
    <div class="msg msg-nex">👋 Bonjour ! Je suis <strong>NEX</strong>, votre assistant Nexio.<br>Je peux vous conseiller des produits, suivre vos commandes ou répondre à vos questions.</div>
  </div>
  <form class="nex-form" id="nexForm">
    <input type="text" class="nex-input" id="nexInput" placeholder="Posez votre question…" autocomplete="off">
    <button type="submit" class="nex-send"><i class="bi bi-send-fill"></i></button>
  </form>
</div>

<!-- Back to top -->
<button id="backTop" aria-label="Retour en haut"><i class="bi bi-arrow-up"></i></button>

<!-- Progress bar -->
<div id="progress-bar"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
/* ── NAV MOBILE ────────────────────────────────────────── */
const navToggler = document.getElementById('navToggler');
const navMenu    = document.getElementById('navMobileMenu');
if(navToggler && navMenu) {
  navToggler.addEventListener('click', () => {
    navMenu.classList.toggle('open');
    const icon = navToggler.querySelector('i');
    icon.className = navMenu.classList.contains('open') ? 'bi bi-x-lg' : 'bi bi-list';
  });
}

/* ── CHATBOT NEX ────────────────────────────────────────── */
const nexToggle  = document.getElementById('nexToggle');
const nexBubble  = document.getElementById('nexBubble');
const nexClose   = document.getElementById('nexClose');
const nexForm    = document.getElementById('nexForm');
const nexInput   = document.getElementById('nexInput');
const nexMessages= document.getElementById('nexMessages');
let nexOpen = false;

function toggleNex() {
  nexOpen = !nexOpen;
  nexBubble.classList.toggle('open', nexOpen);
  if (nexOpen) { nexBubble.style.display='flex'; setTimeout(()=>nexInput.focus(),200); }
  nexToggle.innerHTML = nexOpen
    ? '<i class="bi bi-x-lg"></i>'
    : '<i class="bi bi-robot"></i><span class="nex-pulse"></span>';
}

nexToggle.addEventListener('click', toggleNex);
nexClose.addEventListener('click', toggleNex);

function addMsg(text, role='nex') {
  const d = document.createElement('div');
  d.className = `msg msg-${role}`;
  d.innerHTML = text;
  nexMessages.appendChild(d);
  nexMessages.scrollTop = nexMessages.scrollHeight;
  return d;
}

function showTyping() {
  const d = document.createElement('div');
  d.className = 'msg-typing msg-nex';
  d.innerHTML = '<div class="dot-t"></div><div class="dot-t"></div><div class="dot-t"></div>';
  d.id = 'nexTyping';
  nexMessages.appendChild(d);
  nexMessages.scrollTop = nexMessages.scrollHeight;
}

nexForm.addEventListener('submit', async (e) => {
  e.preventDefault();
  const msg = nexInput.value.trim();
  if (!msg) return;
  addMsg(msg, 'user');
  nexInput.value = '';
  showTyping();
  try {
    const r = await fetch('/api/chat', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ message:msg, session_id: (sessionStorage.getItem('nex_session')||crypto.randomUUID()) })
    });
    const data = await r.json();
    document.getElementById('nexTyping')?.remove();
    addMsg(data.reply || 'Désolé, je n\'ai pas pu traiter votre demande.', 'nex');
    sessionStorage.setItem('nex_session', data.session_id || 'session');
  } catch {
    document.getElementById('nexTyping')?.remove();
    addMsg('⚠️ Service temporairement indisponible. Appelez-nous au <strong>4810-8541</strong>.', 'nex');
  }
});

/* ── BACK TO TOP ────────────────────────────────────────── */
const backTop = document.getElementById('backTop');
window.addEventListener('scroll', () => {
  backTop?.classList.toggle('show', window.scrollY > 400);
  // Progress bar
  const pb = document.getElementById('progress-bar');
  if(pb) {
    const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
    pb.style.width = Math.min(pct, 100) + '%';
  }
}, { passive: true });
backTop?.addEventListener('click', () => window.scrollTo({ top:0, behavior:'smooth' }));

/* ── ANIMATIONS SCROLL ──────────────────────────────────── */
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('animated'); });
}, { threshold: 0.1 });
document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

/* ── FLASH AUTO-DISMISS ─────────────────────────────────── */
document.querySelectorAll('.nx-flash').forEach(el => {
  setTimeout(() => { el.style.transition='opacity .4s'; el.style.opacity='0'; setTimeout(()=>el.remove(),400); }, 4500);
});
</script>
