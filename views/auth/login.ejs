<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Connexion — Nexio S.A.</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="/css/nexio.css">
</head>
<body style="background:#06080F;display:flex;align-items:center;justify-content:center;min-height:100vh;padding:1rem;">
<div style="width:100%;max-width:400px;">
  <div style="text-align:center;margin-bottom:2rem;">
    <a href="/" style="font-size:1.5rem;font-weight:900;text-decoration:none;color:#EDF2F7;"><i class="bi bi-cpu-fill" style="color:#00C8FF;"></i> Nexio<span style="color:#00C8FF;">.</span>ht</a>
  </div>
  <div style="background:#0D1117;border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:2rem;">
    <h1 style="font-size:1.2rem;margin-bottom:1.5rem;font-weight:800;">Connexion</h1>
    <% if (flash.error && flash.error.length) { %>
    <div style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:8px;padding:.7rem 1rem;margin-bottom:1rem;color:#FCA5A5;font-size:.83rem;"><i class="bi bi-exclamation-circle-fill me-2"></i><%= flash.error[0] %></div>
    <% } %>
    <% if (flash.success && flash.success.length) { %>
    <div style="background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.2);border-radius:8px;padding:.7rem 1rem;margin-bottom:1rem;color:#6EE7B7;font-size:.83rem;"><i class="bi bi-check-circle-fill me-2"></i><%= flash.success[0] %></div>
    <% } %>
    <form method="POST" action="/auth/login">
      <label class="nx-label">Email</label>
      <input type="email" name="email" class="nx-input" required placeholder="admin@nexio.com" autocomplete="email">
      <label class="nx-label">Mot de passe</label>
      <input type="password" name="password" class="nx-input" required placeholder="••••••••" autocomplete="current-password">
      <button type="submit" class="btn-nx-primary" style="width:100%;justify-content:center;padding:.75rem;font-size:.95rem;margin-top:.5rem;">
        <i class="bi bi-box-arrow-in-right"></i>Se connecter
      </button>
    </form>
    <div style="text-align:center;margin-top:1.2rem;font-size:.82rem;color:#64748B;">
      Pas encore de compte ? <a href="/auth/register" style="color:#00C8FF;font-weight:600;">S'inscrire</a>
    </div>
  </div>
  <div style="text-align:center;margin-top:1rem;font-size:.75rem;color:#374151;">
    <a href="/" style="color:#374151;">← Retour à la boutique</a>
  </div>
</div>
</body></html>
