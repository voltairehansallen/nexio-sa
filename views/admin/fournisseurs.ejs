<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= title %> — Nexio Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script>const BASE_URL='<%- BASE_URL %>';</script>
<%- include('./admin_styles') %>
</head><body>
<%- include('./admin_sidebar', { page: page, stats: stats }) %>
<div class="main" id="mainContent">
<%- include('./admin_topbar', { title: title }) %>
<div class="content">
<%- include('./admin_flash') %>

<div class="form-card">
  <div class="form-card-title"><i class="bi bi-<%= edit?'pencil-fill':'plus-circle-fill' %>"></i><%= edit?'Modifier':'Nouveau' %> fournisseur</div>
  <form method="POST" action="/admin/fournisseurs">
    <input type="hidden" name="id" value="<%= edit?edit.id_fournisseur:'' %>">
    <div class="grid3">
      <div><label class="nx-label">Nom *</label><input type="text" name="nom" class="nx-input" required value="<%= edit?edit.nom:'' %>"></div>
      <div><label class="nx-label">Email</label><input type="email" name="email" class="nx-input" value="<%= edit?edit.email||'':'' %>"></div>
      <div><label class="nx-label">Téléphone</label><input type="text" name="telephone" class="nx-input" value="<%= edit?edit.telephone||'':'' %>"></div>
      <div style="grid-column:1/3"><label class="nx-label">Adresse</label><input type="text" name="adresse" class="nx-input" value="<%= edit?edit.adresse||'':'' %>"></div>
      <div><label class="nx-label">Pays</label><input type="text" name="pays" class="nx-input" placeholder="Haïti, USA…" value="<%= edit?edit.pays||'':'' %>"></div>
    </div>
    <div style="display:flex;gap:.6rem;">
      <button class="btn btn-success" type="submit"><i class="bi bi-check-lg"></i>Enregistrer</button>
      <% if(edit){ %><a href="/admin/fournisseurs" class="btn btn-ghost"><i class="bi bi-x-lg"></i>Annuler</a><% } %>
    </div>
  </form>
</div>

<div class="card">
  <div class="card-hd">
    <div class="card-hd-title"><i class="bi bi-building text-cyan"></i><%= total %> fournisseur(s)</div>
    <form method="GET" action="/admin/fournisseurs" class="srow">
      <input type="text" name="q" placeholder="🔍 Rechercher…" value="<%= q %>">
      <button class="btn btn-primary btn-sm" type="submit"><i class="bi bi-search"></i></button>
      <% if(q){ %><a href="/admin/fournisseurs" class="btn btn-ghost btn-sm"><i class="bi bi-x-lg"></i></a><% } %>
    </form>
  </div>
  <div class="tbl-wrap"><table><thead><tr><th>Nom</th><th>Email</th><th>Téléphone</th><th>Pays</th><th>Produits</th><th>Actions</th></tr></thead><tbody>
  <% rows.forEach(f => { %>
  <tr>
    <td><strong><%= f.nom %></strong></td>
    <td style="font-size:.75rem;"><%= f.email||'—' %></td>
    <td class="text-muted" style="font-size:.75rem;"><%= f.telephone||'—' %></td>
    <td class="text-muted"><%= f.pays||'—' %></td>
    <td><span class="badge b-ship"><%= f.nb_produits||0 %></span></td>
    <td>
      <div style="display:flex;gap:.35rem;">
        <a href="/admin/fournisseurs?edit=<%= f.id_fournisseur %>" class="btn btn-warn btn-sm"><i class="bi bi-pencil-fill"></i></a>
        <a href="/admin/fournisseurs/delete/<%= f.id_fournisseur %>" class="btn btn-danger btn-sm" onclick="return confirm('Supprimer ?')"><i class="bi bi-trash-fill"></i></a>
      </div>
    </td>
  </tr>
  <% }) %>
  <% if(!rows.length){ %><tr><td colspan="6"><div class="empty-state"><i class="bi bi-building"></i>Aucun fournisseur</div></td></tr><% } %>
  </tbody></table></div>
  <% if(pages>1){ %>
  <div class="pagi">
    <% for(let i=1;i<=pages;i++){ %>
      <% if(i===pg){ %><span class="cur"><%= i %></span>
      <% }else{ %><a href="/admin/fournisseurs?pg=<%= i %>&q=<%= q %>"><%= i %></a><% } %>
    <% } %>
  </div>
  <% } %>
</div>
<%- include('./admin_topbar_end') %>
</div></div>
<script>
function toggleSidebar(){const sb=document.getElementById('sidebar');sb.style.transform=sb.style.transform==='translateX(0px)'?'translateX(-100%)':'translateX(0px)';}
if(window.innerWidth<1024)document.getElementById('sidebar').style.transform='translateX(-100%)';
document.querySelectorAll('.flash').forEach(el=>setTimeout(()=>{el.style.opacity='0';setTimeout(()=>el.remove(),400);},4500));
</script>
</body></html>
