<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title><%= title %> — Nexio Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>const BASE_URL = ('<%- BASE_URL %>' || window.location.origin);</script>
<%- include('./admin_styles') %>
</head><body>
<%- include('./admin_sidebar', { page: page, stats: stats }) %>
<div class="main" id="mainContent">
<%- include('./admin_topbar', { title: title }) %>
<div class="content">
<%- include('./admin_flash') %>

<% if(detail){ const o=detail; %>
<div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.1rem;">
  <a href="/admin/commandes" class="btn btn-ghost"><i class="bi bi-arrow-left"></i>Retour</a>
  <h2 style="font-size:.92rem;font-weight:800;">Commande #CMD-<%= String(o.id_commande).padStart(5,'0') %></h2>
  <%- badgeStatut(o.statut) %>
</div>
<div class="dash-grid" style="margin-bottom:1.1rem;">
  <div class="card">
    <div class="card-hd"><div class="card-hd-title"><i class="bi bi-person-fill text-cyan"></i>Client</div></div>
    <div class="card-body">
      <div style="font-weight:800;font-size:.95rem;"><%= o.prenom %> <%= o.nom %></div>
      <div style="color:#64748B;font-size:.82rem;"><%= o.email||'' %></div>
      <div style="color:#64748B;font-size:.82rem;"><%= o.telephone||'' %></div>
      <% if(o.adresse_livraison){ %><div style="margin-top:.6rem;background:#060A12;border-radius:8px;padding:.55rem .8rem;font-size:.8rem;"><i class="bi bi-geo-alt-fill text-cyan me-1"></i><%= o.adresse_livraison %></div><% } %>
    </div>
  </div>
  <div class="card">
    <div class="card-hd"><div class="card-hd-title"><i class="bi bi-sliders text-cyan"></i>Changer le statut</div></div>
    <div class="card-body">
      <div style="font-size:1.4rem;font-weight:900;color:#00C8FF;margin-bottom:.75rem;"><%= Number(o.montant).toLocaleString() %> <span style="font-size:.8rem;color:#64748B;">HTG</span></div>
      <form method="POST" action="/admin/commandes/statut" style="display:flex;gap:.5rem;flex-wrap:wrap;">
        <input type="hidden" name="id" value="<%= o.id_commande %>">
        <select name="statut" class="nx-input" style="margin:0;flex:1;min-width:140px;">
          <% ['En attente','Confirmée','Expédiée','Livrée','Annulée'].forEach(s=>{ %><option value="<%= s %>" <%= o.statut===s?'selected':'' %>><%= s %></option><% }) %>
        </select>
        <button class="btn btn-success" type="submit"><i class="bi bi-check-lg"></i>Maj</button>
      </form>
    </div>
  </div>
</div>
<div class="card">
  <div class="card-hd"><div class="card-hd-title"><i class="bi bi-bag-fill text-cyan"></i>Articles</div></div>
  <div class="tbl-wrap"><table><thead><tr><th>Img</th><th>Produit</th><th>Qté</th><th>Prix u.</th><th>Total</th></tr></thead><tbody>
  <% detailItems.forEach(it=>{ %>
  <tr>
    <td><% if(it.image){ %><img src="<%= it.image %>" class="img-thumb" onerror="this.style.display='none'" alt=""><% } %></td>
    <td><strong><%= it.nom||'—' %></strong></td>
    <td><%= it.quantite %></td>
    <td><%= Number(it.prix).toLocaleString() %> HTG</td>
    <td><strong><%= Number(it.prix*it.quantite).toLocaleString() %> HTG</strong></td>
  </tr>
  <% }) %>
  </tbody></table></div>
</div>
<% } else { %>
<div class="card">
  <div class="card-hd">
    <div class="card-hd-title"><i class="bi bi-bag-check-fill text-cyan"></i><%= total %> commande(s)</div>
    <form method="GET" action="/admin/commandes" class="srow">
      <select name="statut" onchange="this.form.submit()"><option value="">Tous statuts</option>
        <% ['En attente','Confirmée','Expédiée','Livrée','Annulée'].forEach(s=>{ %><option value="<%= s %>" <%= statut_f===s?'selected':'' %>><%= s %></option><% }) %>
      </select>
      <% if(statut_f){ %><a href="/admin/commandes" class="btn btn-ghost btn-sm"><i class="bi bi-x-lg"></i></a><% } %>
    </form>
  </div>
  <div class="tbl-wrap"><table><thead><tr><th>Réf</th><th>Client</th><th>Email</th><th>Montant</th><th>Statut</th><th>Date</th><th>Actions</th></tr></thead><tbody>
  <% rows.forEach(o=>{ %>
  <tr>
    <td><strong style="font-size:.72rem;color:#94A3B8;">#<%= String(o.id_commande).padStart(5,'0') %></strong></td>
    <td style="font-weight:600;"><%= o.prenom %> <%= o.nom %></td>
    <td class="text-muted" style="font-size:.74rem;"><%= o.email||'' %></td>
    <td><strong><%= Number(o.montant).toLocaleString() %></strong> <small class="text-muted">HTG</small></td>
    <td><%- badgeStatut(o.statut) %></td>
    <td class="text-muted" style="font-size:.73rem;"><%= new Date(o.date_commande).toLocaleDateString('fr-FR') %></td>
    <td><div style="display:flex;gap:.35rem;align-items:center;">
      <a href="/admin/commandes?detail=<%= o.id_commande %>" class="btn btn-warn btn-sm"><i class="bi bi-eye-fill"></i></a>
      <form method="POST" action="/admin/commandes/statut" style="display:contents;">
        <input type="hidden" name="id" value="<%= o.id_commande %>">
        <select name="statut" style="font-size:.72rem;padding:.28rem .5rem;background:#060A12;border:1px solid rgba(255,255,255,.08);border-radius:6px;color:#EDF2F7;" onchange="this.form.submit()">
          <% ['En attente','Confirmée','Expédiée','Livrée','Annulée'].forEach(s=>{ %><option value="<%= s %>" <%= o.statut===s?'selected':'' %>><%= s %></option><% }) %>
        </select>
      </form>
    </div></td>
  </tr>
  <% }) %>
  <% if(!rows.length){ %><tr><td colspan="7"><div class="empty-state"><i class="bi bi-bag"></i>Aucune commande</div></td></tr><% } %>
  </tbody></table></div>
  <%- pagi(pages,pg,'?statut='+encodeURIComponent(statut_f)) %>
</div>
<% } %>
</div></div>
<script>
function toggleSidebar(){const sb=document.getElementById('sidebar');sb.style.transform=sb.style.transform==='translateX(0px)'||sb.style.transform===''&&window.innerWidth>=1024?'translateX(-100%)':'translateX(0px)';}
if(window.innerWidth<1024)document.getElementById('sidebar').style.transform='translateX(-100%)';
document.querySelectorAll('.flash').forEach(el=>setTimeout(()=>{el.style.transition='opacity .4s';el.style.opacity='0';setTimeout(()=>el.remove(),400);},4500));
async function genCampagne(id,btn){if(!confirm('Générer avec NEX IA ?'))return;const orig=btn.innerHTML;btn.innerHTML='<i class="bi bi-hourglass-split"></i>';btn.disabled=true;try{const r=await fetch('/admin/api/ia',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'generer_campagne',id_campagne:id})});const d=await r.json();btn.innerHTML='<i class="bi bi-check-lg"></i>';btn.style.color='#10B981';setTimeout(()=>{btn.innerHTML=orig;btn.style.color='';btn.disabled=false;},2500);showToast(d.msg||'Campagne générée !','success');}catch{btn.innerHTML=orig;btn.disabled=false;showToast('Serveur IA indisponible','error');}}
async function envoyerCampagne(id,btn){if(!confirm('Envoyer cette campagne maintenant ?'))return;const orig=btn.innerHTML;btn.innerHTML='<i class="bi bi-hourglass-split"></i>';btn.disabled=true;try{const r=await fetch('/admin/api/ia',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'envoyer_campagne',id_campagne:id})});const d=await r.json();showToast(`Envoyée: ${d.envoyes||0}/${d.destinataires||0}`,'success');location.reload();}catch{showToast('Erreur envoi','error');}btn.innerHTML=orig;btn.disabled=false;}
async function lancerAnalyseIA(){const r=await fetch('/admin/api/ia',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'rapport_ventes',jours:30})});const d=await r.json();alert(d.analyse_ia||JSON.stringify(d).slice(0,300));}
function showToast(msg,type='success'){const t=document.createElement('div');t.style.cssText='position:fixed;top:70px;right:1.2rem;z-index:9999;padding:.75rem 1.1rem;border-radius:10px;font-size:.83rem;font-weight:700;display:flex;align-items:center;gap:.5rem;box-shadow:0 8px 24px rgba(0,0,0,.4);max-width:340px;animation:slideDown .3s ease;';t.style.cssText+=type==='success'?'background:rgba(16,185,129,.12);border:1px solid rgba(16,185,129,.25);color:#34D399;':'background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);color:#FCA5A5;';t.innerHTML=`<i class="bi bi-${type==='success'?'check-circle':'exclamation-circle'}-fill"></i>${msg}<button onclick="this.parentNode.remove()" style="margin-left:auto;background:none;border:none;color:inherit;cursor:pointer;">×</button>`;document.body.appendChild(t);setTimeout(()=>{t.style.transition='opacity .4s,transform .4s';t.style.opacity='0';t.style.transform='translateX(120%)';setTimeout(()=>t.remove(),400);},4000);}
function badgeStatut(s){const m={'En attente':'b-wait','Confirmée':'b-ship','Expédiée':'b-ship','Livrée':'b-ok','Annulée':'b-cancel','Disponible':'b-avail','Rupture':'b-rupture','Actif':'b-ok','Inactif':'b-cancel','Brouillon':'b-warn','Envoyée':'b-ok','En cours':'b-ship','Approuvé':'b-ok','Rejeté':'b-cancel','Non lu':'b-warn','Lu':'b-ok','Répondu':'b-ship','Terminée':'b-purple','Planifiée':'b-warn'};const cls=m[s]||'b-wait';return`<span class="badge ${cls}">${s}</span>`;}
function pagi(pages,cur,base){if(pages<=1)return'';let h='<div class="pagi">';for(let i=1;i<=pages;i++){const u=base+'&pg='+i;if(i===cur)h+=`<span class="cur">${i}</span>`;else h+=`<a href="${u}">${i}</a>`;}return h+'</div>';}
@keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
</script>
<style>@keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}</style>
</body></html>