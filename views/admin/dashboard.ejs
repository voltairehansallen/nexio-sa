<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= title %> — Nexio Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>const BASE_URL = ('<%- BASE_URL %>' || window.location.origin);</script>
<%- include('./admin_styles') %>
</head>
<body>
<%- include('./admin_sidebar', { page: 'dashboard' }) %>
<div class="main" id="mainContent">
  <%- include('./admin_topbar', { title: 'Tableau de bord' }) %>
  <div class="content">
    <%- include('./admin_flash') %>

    <div class="kpi-grid">
      <% [
        { val: stats.produits,   lbl:'Produits',         color:'#00C8FF', icon:'bi-box-seam-fill',      accent:'rgba(0,200,255,.08)'   },
        { val: stats.commandes,  lbl:'Commandes',        color:'#60A5FA', icon:'bi-bag-check-fill',      accent:'rgba(96,165,250,.08)'  },
        { val: stats.en_attente, lbl:'En attente',       color:'#F59E0B', icon:'bi-hourglass',           accent:'rgba(245,158,11,.08)'  },
        { val: stats.clients,    lbl:'Clients',          color:'#34D399', icon:'bi-people-fill',         accent:'rgba(52,211,153,.08)'  },
        { val: Number(stats.ca).toLocaleString()+'k', lbl:'CA total HTG', color:'#A5B4FC', icon:'bi-cash-stack', accent:'rgba(165,180,252,.08)' },
        { val: stats.ca_mois>0?Math.round(stats.ca_mois/1000)+'k':0, lbl:'CA ce mois', color:'#FB923C', icon:'bi-graph-up-arrow', accent:'rgba(251,146,60,.08)' },
      ].forEach(k => { %>
      <div class="kpi" style="--accent:<%= k.color %>;">
        <div class="kpi-top">
          <div class="kpi-ic" style="background:<%= k.accent %>;color:<%= k.color %>;"><i class="bi <%= k.icon %>"></i></div>
        </div>
        <div class="kpi-val"><%= k.val %></div>
        <div class="kpi-lbl"><%= k.lbl %></div>
      </div>
      <% }) %>
    </div>

    <div class="dash-grid">
      <div class="card">
        <div class="card-hd"><div class="card-hd-title"><i class="bi bi-bar-chart-fill text-cyan"></i>Ventes — 7 derniers jours</div></div>
        <div class="chart-wrap"><canvas id="chartVentes"></canvas></div>
      </div>
      <div class="card">
        <div class="card-hd"><div class="card-hd-title"><i class="bi bi-trophy-fill" style="color:#F59E0B;"></i>Top 5 produits vendus</div></div>
        <div class="card-body" style="padding-top:.5rem;">
          <% top5.forEach((t,i) => {
            const pct = top5[0].qte > 0 ? Math.round(t.qte/top5[0].qte*100) : 10;
          %>
          <div style="margin-bottom:.75rem;">
            <div style="display:flex;justify-content:space-between;font-size:.78rem;margin-bottom:.3rem;">
              <span style="font-weight:600;"><%= t.nom.substring(0,30) %></span>
              <span style="color:var(--muted);font-weight:700;"><%= t.qte %> u.</span>
            </div>
            <div style="height:5px;background:rgba(255,255,255,.05);border-radius:3px;overflow:hidden;">
              <div style="width:<%= pct %>%;height:100%;background:linear-gradient(90deg,#1D4ED8,#00C8FF);border-radius:3px;"></div>
            </div>
          </div>
          <% }) %>
          <% if (!top5.length) { %><div class="empty-state"><i class="bi bi-bar-chart"></i>Aucune vente</div><% } %>
        </div>
      </div>
    </div>

    <div class="dash-grid">
      <div class="card">
        <div class="card-hd"><div class="card-hd-title"><i class="bi bi-bag-check-fill text-cyan"></i>Dernières commandes</div><a href="/admin/commandes" class="btn btn-ghost btn-sm"><i class="bi bi-arrow-right"></i>Tout voir</a></div>
        <div class="tbl-wrap"><table><thead><tr><th>Réf</th><th>Client</th><th>Montant</th><th>Statut</th><th></th></tr></thead><tbody>
        <% recent.forEach(o => { %>
        <tr>
          <td><strong style="font-size:.72rem;color:#94A3B8;">#<%- String(o.id_commande).padStart(5,'0') %></strong></td>
          <td style="font-weight:600;"><%= o.prenom %> <%= o.nom %></td>
          <td><strong><%= Number(o.montant).toLocaleString() %></strong> <small class="text-muted">HTG</small></td>
          <td><%- badgeStatut(o.statut) %></td>
          <td><a href="/admin/commandes?detail=<%= o.id_commande %>" class="btn btn-ghost btn-sm"><i class="bi bi-eye"></i></a></td>
        </tr>
        <% }) %>
        <% if (!recent.length) { %><tr><td colspan="5"><div class="empty-state"><i class="bi bi-bag"></i>Aucune commande</div></td></tr><% } %>
        </tbody></table></div>
      </div>
      <div class="card">
        <div class="card-hd"><div class="card-hd-title"><i class="bi bi-exclamation-triangle-fill" style="color:#F59E0B;"></i>Alertes stock</div><a href="/admin/stocks?alerte=bas" class="btn btn-ghost btn-sm"><i class="bi bi-arrow-right"></i>Gérer</a></div>
        <div class="tbl-wrap"><table><thead><tr><th>Produit</th><th>Qté</th><th>Seuil</th></tr></thead><tbody>
        <% if (!alerts.length) { %>
        <tr><td colspan="3"><div class="empty-state" style="padding:1.5rem;"><i class="bi bi-check-circle" style="color:#10B981;"></i>Stocks OK</div></td></tr>
        <% } else { alerts.forEach(s => { %>
        <tr><td style="font-weight:600;"><%= s.nom %></td><td style="color:<%= s.quantite==0?'#EF4444':'#F59E0B' %>;font-weight:800;"><%= s.quantite %></td><td class="text-muted"><%= s.seuil_alerte %></td></tr>
        <% }) } %>
        </tbody></table></div>
      </div>
    </div>

    <div class="card">
      <div class="card-hd"><div class="card-hd-title"><i class="bi bi-lightning-charge-fill text-cyan"></i>Actions rapides</div></div>
      <div class="card-body" style="display:flex;gap:.75rem;flex-wrap:wrap;">
        <a href="/admin/produits" class="btn btn-primary"><i class="bi bi-plus-circle-fill"></i>Nouveau produit</a>
        <a href="/admin/commandes?statut=En+attente" class="btn btn-warn"><i class="bi bi-bag-check"></i>Commandes en attente<% if(stats.en_attente>0){%><span class="sb-badge" style="margin-left:.25rem;"><%= stats.en_attente %></span><%}%></a>
        <button class="btn btn-ia" onclick="lancerAnalyseIA()"><i class="bi bi-robot"></i>Analyse IA</button>
        <a href="/admin/rapports" class="btn btn-ghost"><i class="bi bi-bar-chart-fill"></i>Rapports</a>
      </div>
    </div>
  </div>
</div>

<script>
<%- chartJS_7days(chart7) %>
<%- adminJS %>
</script>
</body></html>
