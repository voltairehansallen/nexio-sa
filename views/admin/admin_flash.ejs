<% if(flash.success&&flash.success.length){%><div class="flash flash-success"><i class="bi bi-check-circle-fill"></i><%= flash.success[0] %><button onclick="this.parentNode.remove()" style="margin-left:auto;background:none;border:none;color:inherit;cursor:pointer;font-size:1rem;">×</button></div><%}%>
<% if(flash.error&&flash.error.length){%><div class="flash flash-danger"><i class="bi bi-exclamation-circle-fill"></i><%= flash.error[0] %><button onclick="this.parentNode.remove()" style="margin-left:auto;background:none;border:none;color:inherit;cursor:pointer;font-size:1rem;">×</button></div><%}%>