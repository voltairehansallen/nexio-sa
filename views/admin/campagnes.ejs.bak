<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title><%= title %> — Nexio Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>const BASE_URL='<%- BASE_URL %>';</script>
<%- include('./admin_styles') %>
</head><body>
<%- include('./admin_sidebar', { page: page, stats: stats }) %>
<div class="main" id="mainContent">
<%- include('./admin_topbar', { title: title }) %>
<div class="content">
<%- include('./admin_flash') %>

<div class="form-card">
  <div class="form-card-title"><i class="bi bi-<%= edit?'pencil-fill':'megaphone-fill' %>"></i><%= edit?'Modifier':'Nouvelle' %> campagne</div>
  <form method="POST" action="/admin/campagnes">
    <input type="hidden" name="id" value="<%= edit?edit.id_campagne:'' %>">
    <div class="grid3">
      <div style="grid-column:1/3"><label class="nx-label">Nom *</label><input type="text" name="nom" class="nx-input" required value="<%= edit?edit.nom:'' %>"></div>
      <div><label class="nx-label">Canal</label><select name="canal" class="nx-input">
        <% ['Email','WhatsApp','Facebook','Notification'].forEach(c=>{ %><option value="<%= c %>" <%= (edit?edit.canal:'Email')===c?'selected':'' %>><%= c %></option><% }) %>
      </select></div>
    </div>
    <label class="nx-label">Contenu</label>
    <textarea name="contenu" class="nx-input" rows="4"><%= edit?edit.contenu||'':'' %></textarea>
    <div class="grid2">
      <div><label class="nx-label">Date envoi programmée</label><input type="datetime-local" name="date_envoi" class="nx-input" value="<%= edit&&edit.date_envoi?edit.date_envoi:'' %>"></div>
      <div><label class="nx-label">Statut</label><select name="statut" class="nx-input">
        <% ['Brouillon','En cours','Envoyée','Annulée'].forEach(s=>{ %><option value="<%= s %>" <%= (edit?edit.statut:'Brouillon')===s?'selected':'' %>><%= s %></option><% }) %>
      </select></div>
    </div>
    <div style="display:flex;gap:.6rem;flex-wrap:wrap;">
      <button class="btn btn-success" type="submit"><i class="bi bi-check-lg"></i>Enregistrer</button>
      <% if(edit){ %><a href="/admin/campagnes" class="btn btn-ghost"><i class="bi bi-x-lg"></i>Annuler</a><% } %>
    </div>
  </form>
</div>
<div class="card">
  <div class="card-hd"><div class="card-hd-title"><i class="bi bi-megaphone-fill text-cyan"></i><%= total %> campagne(s)</div></div>
  <div class="tbl-wrap"><table><thead><tr><th>Campagne</th><th>Canal</th><th>Statut</th><th>Date envoi</th><th>Actions</th></tr></thead><tbody>
  <% rows.forEach(c=>{ %>
  <tr>
    <td><div style="font-weight:700;"><%= c.nom.substring(0,38) %></div>
      <% if(c.contenu){ %><div class="text-muted" style="font-size:.7rem;margin-top:.2rem;"><%= c.contenu.substring(0,48) %>…</div><% } %>
    </td>
    <td><span class="badge b-ship"><%= c.canal %></span></td>
    <td><%- badgeStatut(c.statut) %></td>
    <td class="text-muted" style="font-size:.73rem;"><%= c.date_envoi?new Date(c.date_envoi).toLocaleDateString('fr-FR'):'—' %></td>
    <td><div style="display:flex;gap:.35rem;flex-wrap:wrap;">
      <a href="/admin/campagnes?edit=<%= c.id_campagne %>" class="btn btn-warn btn-sm"><i class="bi bi-pencil-fill"></i></a>
      <button class="btn btn-ia btn-sm" onclick="genCampagne(<%= c.id_campagne %>,this)"><i class="bi bi-robot"></i>NEX IA</button>
      <% if(!['Envoyée','Terminée'].includes(c.statut)){ %><button class="btn btn-success btn-sm" onclick="envoyerCampagne(<%= c.id_campagne %>,this)"><i class="bi bi-send-fill"></i>Envoyer</button><% } %>
      <a href="/admin/campagnes/delete/<%= c.id_campagne %>" class="btn btn-danger btn-sm" onclick="return confirm('Supprimer ?')"><i class="bi bi-trash-fill"></i></a>
    </div></td>
  </tr>
  <% }) %>
  <% if(!rows.length){ %><tr><td colspan="5"><div class="empty-state"><i class="bi bi-megaphone"></i>Aucune campagne</div></td></tr><% } %>
  </tbody></table></div>
  <%- pagi(pages,pg,'?') %>
</div>
</div></div>
<script>
function toggleSidebar(){const sb=document.getElementById('sidebar');sb.style.transform=sb.style.transform==='translateX(0px)'||sb.style.transform===''&&window.innerWidth>=1024?'translateX(-100%)':'translateX(0px)';}
if(window.innerWidth<1024)document.getElementById('sidebar').style.transform='translateX(-100%)';
document.querySelectorAll('.flash').forEach(el=>setTimeout(()=>{el.style.transition='opacity .4s';el.style.opacity='0';setTimeout(()=>el.remove(),400);},4500));
async function genCampagne(id,btn){if(!confirm('Générer avec NEX IA ?'))return;const orig=btn.innerHTML;btn.innerHTML='<i class="bi bi-hourglass-split"></i>';btn.disabled=true;try{const r=await fetch(BASE_URL+'/admin/api/ia',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'generer_campagne',id_campagne:id})});const d=await r.json();btn.innerHTML='<i class="bi bi-check-lg"></i>';btn.style.color='#10B981';setTimeout(()=>{btn.innerHTML=orig;btn.style.color='';btn.disabled=false;},2500);showToast(d.msg||'Campagne générée !','success');}catch{btn.innerHTML=orig;btn.disabled=false;showToast('Serveur IA indisponible','error');}}
async function envoyerCampagne(id,btn){if(!confirm('Envoyer cette campagne maintenant ?'))return;const orig=btn.innerHTML;btn.innerHTML='<i class="bi bi-hourglass-split"></i>';btn.disabled=true;try{const r=await fetch(BASE_URL+'/admin/api/ia',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'envoyer_campagne',id_campagne:id})});const d=await r.json();showToast(`Envoyée: ${d.envoyes||0}/${d.destinataires||0}`,'success');location.reload();}catch{showToast('Erreur envoi','error');}btn.innerHTML=orig;btn.disabled=false;}
async function lancerAnalyseIA(){const r=await fetch(BASE_URL+'/admin/api/ia',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'rapport_ventes',jours:30})});const d=await r.json();alert(d.analyse_ia||JSON.stringify(d).slice(0,300));}
function showToast(msg,type='success'){const t=document.createElement('div');t.style.cssText='position:fixed;top:70px;right:1.2rem;z-index:9999;padding:.75rem 1.1rem;border-radius:10px;font-size:.83rem;font-weight:700;display:flex;align-items:center;gap:.5rem;box-shadow:0 8px 24px rgba(0,0,0,.4);max-width:340px;animation:slideDown .3s ease;';t.style.cssText+=type==='success'?'background:rgba(16,185,129,.12);border:1px solid rgba(16,185,129,.25);color:#34D399;':'background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);color:#FCA5A5;';t.innerHTML=`<i class="bi bi-${type==='success'?'check-circle':'exclamation-circle'}-fill"></i>${msg}<button onclick="this.parentNode.remove()" style="margin-left:auto;background:none;border:none;color:inherit;cursor:pointer;">×</button>`;document.body.appendChild(t);setTimeout(()=>{t.style.transition='opacity .4s,transform .4s';t.style.opacity='0';t.style.transform='translateX(120%)';setTimeout(()=>t.remove(),400);},4000);}
function badgeStatut(s){const m={'En attente':'b-wait','Confirmée':'b-ship','Expédiée':'b-ship','Livrée':'b-ok','Annulée':'b-cancel','Disponible':'b-avail','Rupture':'b-rupture','Actif':'b-ok','Inactif':'b-cancel','Brouillon':'b-warn','Envoyée':'b-ok','En cours':'b-ship','Approuvé':'b-ok','Rejeté':'b-cancel','Non lu':'b-warn','Lu':'b-ok','Répondu':'b-ship','Terminée':'b-purple','Planifiée':'b-warn'};const cls=m[s]||'b-wait';return`<span class="badge ${cls}">${s}</span>`;}
function pagi(pages,cur,base){if(pages<=1)return'';let h='<div class="pagi">';for(let i=1;i<=pages;i++){const u=base+'&pg='+i;if(i===cur)h+=`<span class="cur">${i}</span>`;else h+=`<a href="${u}">${i}</a>`;}return h+'</div>';}
@keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
</script>
<style>@keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}</style>
</body></html>