<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<div class="nx-section">
  <div class="sec-hd mb-4"><h1 style="font-size:1.6rem;"><i class="bi bi-heart-fill" style="color:var(--danger);"></i>Ma liste de souhaits</h1><span style="color:var(--muted);font-size:.85rem;"><%= items.length %> produit(s)</span></div>
  <% if (!items.length) { %>
  <div style="text-align:center;padding:5rem 0;">
    <i class="bi bi-heart" style="font-size:3.5rem;color:var(--muted);display:block;margin-bottom:1rem;"></i>
    <h3 style="color:var(--muted);">Votre liste de souhaits est vide</h3>
    <a href="/" class="btn-nx-primary" style="display:inline-flex;margin-top:1.2rem;"><i class="bi bi-grid-fill"></i>Parcourir le catalogue</a>
  </div>
  <% } else { %>
  <div class="product-grid">
    <% items.forEach(p => { %>
    <div class="pcard">
      <div class="pcard-img" onclick="location.href='/produit/<%= p.id_produit %>';cursor:pointer;">
        <% if(p.image){ %><img src="<%= p.image %>" alt="<%= p.nom %>" loading="lazy" onerror="this.style.display='none'"><% } else { %><div class="no-img" style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;font-size:3rem;color:rgba(255,255,255,.05);"><i class="bi bi-cpu"></i></div><% } %>
      </div>
      <div class="pcard-body">
        <div class="pcard-brand"><%= p.marque || '' %></div>
        <div class="pcard-name"><%= p.nom %></div>
        <div class="pcard-price"><%= Number(p.prix).toLocaleString() %><span class="cur">HTG</span></div>
        <div style="margin-bottom:.6rem;"><span class="nx-badge <%= p.statut==='Disponible'?'nx-badge-success':'nx-badge-danger' %>"><%= p.statut %></span></div>
        <div style="display:flex;flex-direction:column;gap:.4rem;">
          <a href="/wishlist/move-to-cart/<%= p.id_produit %>" class="btn-nx-primary" style="width:100%;justify-content:center;"><i class="bi bi-cart-plus"></i>Déplacer au panier</a>
          <a href="/wishlist/toggle/<%= p.id_produit %>" class="btn-nx-ghost" style="width:100%;justify-content:center;font-size:.78rem;"><i class="bi bi-trash"></i>Retirer</a>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
