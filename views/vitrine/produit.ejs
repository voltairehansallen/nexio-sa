<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<div class="nx-section">
  <nav style="font-size:.78rem;color:var(--muted);margin-bottom:1.2rem;">
    <a href="/" style="color:var(--muted);">Accueil</a> › <a href="/" style="color:var(--muted);"><%= prod.categorie||'Catalogue' %></a> › <span style="color:var(--text2);"><%= prod.nom.substring(0,30) %></span>
  </nav>
  <div class="row g-4">
    <div class="col-12 col-md-5" data-animate>
      <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:2rem;display:flex;align-items:center;justify-content:center;min-height:300px;position:sticky;top:80px;">
        <% if(prod.image){ %>
          <img src="<%= prod.image %>" alt="<%= prod.nom %>" style="max-width:100%;max-height:340px;object-fit:contain;" onerror="this.style.display='none'">
        <% } else { %>
          <i class="bi bi-cpu" style="font-size:5rem;color:rgba(255,255,255,.06);"></i>
        <% } %>
      </div>
    </div>
    <div class="col-12 col-md-7" data-animate style="animation-delay:.08s;">
      <% if(prod.marque){ %><div style="font-size:.75rem;font-weight:800;color:var(--cyan);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.4rem;"><%= prod.marque %></div><% } %>
      <h1 style="font-size:1.4rem;font-weight:900;margin-bottom:.5rem;line-height:1.3;"><%= prod.nom %></h1>
      <div style="display:flex;align-items:center;gap:.8rem;margin-bottom:1.2rem;flex-wrap:wrap;">
        <span style="font-size:1.8rem;font-weight:900;color:var(--cyan);"><%= Number(prod.prix).toLocaleString() %> <span style="font-size:.9rem;color:var(--muted);">HTG</span></span>
        <% if(prod.statut==='Disponible'){ %><span class="nx-badge nx-badge-success"><i class="bi bi-check-circle-fill"></i>En stock</span>
        <% } else { %><span class="nx-badge nx-badge-danger"><i class="bi bi-x-circle-fill"></i><%= prod.statut %></span><% } %>
      </div>
      <% if(prod.description){ %><p style="color:var(--text2);line-height:1.7;font-size:.88rem;margin-bottom:1.2rem;"><%= prod.description %></p><% } %>
      <div class="row g-2 mb-3">
        <% if(prod.garantie){ %><div class="col-auto"><div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:.4rem .75rem;font-size:.75rem;display:inline-flex;align-items:center;gap:.35rem;"><i class="bi bi-shield-check-fill" style="color:var(--cyan);"></i>Garantie : <%= prod.garantie %></div></div><% } %>
        <% if(prod.marque){ %><div class="col-auto"><div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:.4rem .75rem;font-size:.75rem;display:inline-flex;align-items:center;gap:.35rem;"><i class="bi bi-award-fill" style="color:var(--cyan);"></i><%= prod.marque %></div></div><% } %>
        <% if(prod.categorie){ %><div class="col-auto"><div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:.4rem .75rem;font-size:.75rem;display:inline-flex;align-items:center;gap:.35rem;"><i class="bi bi-tag-fill" style="color:var(--cyan);"></i><%= prod.categorie %></div></div><% } %>
      </div>
      <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:1rem;">
        <a href="/panier/ajouter?id=<%= prod.id_produit %>&qty=1" class="btn-nx-primary">
          <i class="bi bi-cart-plus-fill"></i>Ajouter au panier
        </a>
        <% if(isLoggedIn){ %>
        <a href="/wishlist/toggle/<%= prod.id_produit %>" class="btn-nx-ghost" id="wishBtn">
          <i class="bi bi-heart<%= inWish?'-fill':'' %>" style="color:var(--danger);"></i><%= inWish?'Retirer des favoris':'Ajouter aux favoris' %>
        </a>
        <% } %>
      </div>
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1rem;font-size:.82rem;">
        <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.4rem;"><i class="bi bi-truck" style="color:var(--cyan);"></i><span>Livraison Port-au-Prince sous <strong>24–48h</strong></span></div>
        <div style="display:flex;align-items:center;gap:.5rem;"><i class="bi bi-credit-card" style="color:var(--cyan);"></i><span>MonCash · NatCash · Visa · Espèces</span></div>
      </div>
    </div>
  </div>

  <% if(similaires && similaires.length){ %>
  <div style="margin-top:3rem;" data-animate>
    <h3 style="font-size:1.1rem;margin-bottom:1.2rem;"><i class="bi bi-grid me-2" style="color:var(--cyan);"></i>Produits similaires</h3>
    <div class="product-grid" style="grid-template-columns:repeat(auto-fill,minmax(200px,1fr));">
      <% similaires.slice(0,4).forEach(s=>{ const pid=s.id_produit; %>
      <div class="pcard" onclick="location.href='/produit/<%= pid %>'">
        <div class="pcard-body" style="padding-top:1rem;">
          <div class="pcard-name"><%= s.nom||s.raison||'Produit' %></div>
          <% if(s.prix){ %><div class="pcard-price"><%= Number(s.prix).toLocaleString() %><span class="cur">HTG</span></div><% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
